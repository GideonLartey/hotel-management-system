<UserControl x:Class="LantelHotelApp.Views.CurrencySelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#33000000" CornerRadius="16" Padding="50"
                BorderBrush="#44FFFFFF" BorderThickness="1"
                MaxWidth="500">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🏨" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Welcome to" FontSize="16" Foreground="#AAFFFFFF"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Lantel Hotel" FontSize="32" FontWeight="Bold"
                           Foreground="#e6a817" HorizontalAlignment="Center" Margin="0,5,0,20"/>
                <TextBlock Text="Select your preferred currency" FontSize="14"
                           Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnGhCedi" Content="🇬🇭  GH₵ — Ghana Cedi"
                        Click="GhCedi_Click" Margin="0,0,0,12"
                        Height="50" FontSize="16" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="8" Padding="20,10"
                                    Background="#44e6a817" BorderBrush="#88e6a817" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#88e6a817"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnUSD" Content="🇺🇸  $ — US Dollar"
                        Click="USD_Click" Margin="0,0,0,12"
                        Height="50" FontSize="16" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="8" Padding="20,10"
                                    Background="#440f3460" BorderBrush="#880f3460" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#880f3460"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
