<UserControl x:Class="LantelHotelApp.Views.FinancialReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1a1a2e" Offset="0"/><GradientStop Color="#0f3460" Offset="1"/></LinearGradientBrush></Grid.Background>
        <StackPanel Margin="30,20">
            <Button Content="← Back to Dashboard" Click="Back_Click" HorizontalAlignment="Left" Foreground="#AAFFFFFF" FontSize="12" Cursor="Hand" Margin="0,0,0,15">
                <Button.Template><ControlTemplate TargetType="Button"><TextBlock Text="{TemplateBinding Content}" Foreground="#AAFFFFFF" FontSize="12"/></ControlTemplate></Button.Template>
            </Button>
            <TextBlock Text="💰 Financial Reports" FontSize="24" FontWeight="Bold" Foreground="#e6a817" Margin="0,0,0,15"/>
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,15">
                <Border Background="#33000000" CornerRadius="10" Padding="15" Margin="0,0,8,0" BorderBrush="#44FFFFFF" BorderThickness="1">
                    <StackPanel><TextBlock x:Name="TxtRevenue" Text="0" FontSize="24" FontWeight="Bold" Foreground="#fbbf24"/><TextBlock Text="Total Revenue" Foreground="#AAFFFFFF" FontSize="11"/></StackPanel>
                </Border>
                <Border Background="#33000000" CornerRadius="10" Padding="15" Margin="4,0" BorderBrush="#44FFFFFF" BorderThickness="1">
                    <StackPanel><TextBlock x:Name="TxtAvgRate" Text="0" FontSize="24" FontWeight="Bold" Foreground="#60a5fa"/><TextBlock Text="Avg Room Rate" Foreground="#AAFFFFFF" FontSize="11"/></StackPanel>
                </Border>
                <Border Background="#33000000" CornerRadius="10" Padding="15" Margin="4,0" BorderBrush="#44FFFFFF" BorderThickness="1">
                    <StackPanel><TextBlock x:Name="TxtOccRate" Text="0%" FontSize="24" FontWeight="Bold" Foreground="#4ade80"/><TextBlock Text="Occupancy Rate" Foreground="#AAFFFFFF" FontSize="11"/></StackPanel>
                </Border>
                <Border Background="#33000000" CornerRadius="10" Padding="15" Margin="8,0,0,0" BorderBrush="#44FFFFFF" BorderThickness="1">
                    <StackPanel><TextBlock x:Name="TxtTotalBookings" Text="0" FontSize="24" FontWeight="Bold" Foreground="#c084fc"/><TextBlock Text="Total Bookings" Foreground="#AAFFFFFF" FontSize="11"/></StackPanel>
                </Border>
            </UniformGrid>
            <TextBlock Text="Completed Bookings (Revenue)" Foreground="#CCFFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <DataGrid x:Name="DgRevenue" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" Foreground="White" BorderBrush="#44FFFFFF" RowBackground="#22000000" AlternatingRowBackground="#33000000" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#22FFFFFF" HeadersVisibility="Column" MaxHeight="350">
                <DataGrid.ColumnHeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#44000000"/><Setter Property="Foreground" Value="#e6a817"/><Setter Property="Padding" Value="10,6"/><Setter Property="FontWeight" Value="SemiBold"/></Style></DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ref" Binding="{Binding BookingReference}" Width="100"/>
                    <DataGridTextColumn Header="Room Type" Binding="{Binding RoomType}" Width="120"/>
                    <DataGridTextColumn Header="Nights" Binding="{Binding NightsBooked}" Width="60"/>
                    <DataGridTextColumn Header="Rate/Night" Binding="{Binding RoomCostPerNight, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=N2}" Width="80"/>
                    <DataGridTextColumn Header="Paid" Binding="{Binding AmountPaid, StringFormat=N2}" Width="80"/>
                    <DataGridTextColumn Header="Discount" Binding="{Binding DiscountApplied, StringFormat=P0}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>
