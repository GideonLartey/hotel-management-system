<UserControl x:Class="LantelHotelApp.Views.SearchRoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/><GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel Margin="30,20">
            <Button Content="← Back to Dashboard" Click="Back_Click" HorizontalAlignment="Left" Foreground="#AAFFFFFF" FontSize="12" Cursor="Hand" Margin="0,0,0,15">
                <Button.Template><ControlTemplate TargetType="Button"><TextBlock Text="{TemplateBinding Content}" Foreground="#AAFFFFFF" FontSize="12"/></ControlTemplate></Button.Template>
            </Button>
            <TextBlock Text="🔍 Search Available Rooms" FontSize="24" FontWeight="Bold" Foreground="#e6a817" Margin="0,0,0,15"/>
            <Border Background="#33000000" CornerRadius="12" Padding="20" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Check-In" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DpFrom" Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Check-Out" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DpTo" Width="150"/>
                    </StackPanel>
                    <Button Content="Search" Click="Search_Click" VerticalAlignment="Bottom" Height="35" Width="100" Foreground="White" Cursor="Hand" Margin="0,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="6" Background="#88e6a817" Padding="10,5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#AAe6a817"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
            <DataGrid x:Name="DgRooms" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" Foreground="White" BorderBrush="#44FFFFFF"
                      RowBackground="#22000000" AlternatingRowBackground="#33000000"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#22FFFFFF" HeadersVisibility="Column" MaxHeight="400">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#44000000"/><Setter Property="Foreground" Value="#e6a817"/>
                        <Setter Property="Padding" Value="10,6"/><Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Room #" Binding="{Binding RoomNumber}" Width="80"/>
                    <DataGridTextColumn Header="Floor" Binding="{Binding FloorNumber}" Width="60"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding RoomType}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>
