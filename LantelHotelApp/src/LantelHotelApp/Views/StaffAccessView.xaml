<UserControl x:Class="LantelHotelApp.Views.StaffAccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1a1a2e" Offset="0"/><GradientStop Color="#0f3460" Offset="1"/></LinearGradientBrush></Grid.Background>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
            <StackPanel Margin="20">
                <Button Content="← Back to Dashboard" Click="Back_Click" HorizontalAlignment="Left" Foreground="#AAFFFFFF" FontSize="12" Cursor="Hand" Margin="0,0,0,15">
                    <Button.Template><ControlTemplate TargetType="Button"><TextBlock Text="{TemplateBinding Content}" Foreground="#AAFFFFFF" FontSize="12"/></ControlTemplate></Button.Template>
                </Button>
                <TextBlock Text="👥 Staff Access Management" FontSize="24" FontWeight="Bold" Foreground="#e6a817" Margin="0,0,0,15"/>
                <Border Background="#33000000" CornerRadius="12" Padding="25" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Add New Staff Access" FontSize="16" FontWeight="SemiBold" Foreground="#CCFFFFFF" Margin="0,0,0,15"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Employee ID" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtEmpId" Height="35" FontSize="13" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Padding="8,5" CaretBrush="White"/>
                                <TextBlock Text="Full Name" Foreground="#CCFFFFFF" FontSize="12" Margin="0,10,0,5"/>
                                <TextBox x:Name="TxtFullName" Height="35" FontSize="13" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Padding="8,5" CaretBrush="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Email" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtEmail" Height="35" FontSize="13" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Padding="8,5" CaretBrush="White"/>
                                <TextBlock Text="Role" Foreground="#CCFFFFFF" FontSize="12" Margin="0,10,0,5"/>
                                <ComboBox x:Name="CmbRole" Height="35" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="TxtStatus" Text="" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>
                        <Button Content="Grant Access" Click="AddStaff_Click" Margin="0,15,0,0" Height="40" FontSize="14" FontWeight="SemiBold" Foreground="White" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="8"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#e6a817" Offset="0"/><GradientStop Color="#ff6b35" Offset="1"/></LinearGradientBrush></Border.Background><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Opacity" Value="0.85"/></Trigger></ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
                <TextBlock Text="Current Staff" FontSize="16" FontWeight="SemiBold" Foreground="#CCFFFFFF" Margin="0,0,0,10"/>
                <DataGrid x:Name="DgStaff" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" Foreground="White" BorderBrush="#44FFFFFF" RowBackground="#22000000" AlternatingRowBackground="#33000000" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#22FFFFFF" HeadersVisibility="Column" MaxHeight="300">
                    <DataGrid.ColumnHeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#44000000"/><Setter Property="Foreground" Value="#e6a817"/><Setter Property="Padding" Value="10,6"/><Setter Property="FontWeight" Value="SemiBold"/></Style></DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee ID" Binding="{Binding EmployeeId}" Width="100"/>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="150"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat=dd/MM HH:mm}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
