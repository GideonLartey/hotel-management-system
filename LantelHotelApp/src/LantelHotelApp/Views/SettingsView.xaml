<UserControl x:Class="LantelHotelApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1a1a2e" Offset="0"/><GradientStop Color="#0f3460" Offset="1"/></LinearGradientBrush></Grid.Background>
        <StackPanel Margin="30,20">
            <Button Content="← Back to Dashboard" Click="Back_Click" HorizontalAlignment="Left" Foreground="#AAFFFFFF" FontSize="12" Cursor="Hand" Margin="0,0,0,15">
                <Button.Template><ControlTemplate TargetType="Button"><TextBlock Text="{TemplateBinding Content}" Foreground="#AAFFFFFF" FontSize="12"/></ControlTemplate></Button.Template>
            </Button>
            <TextBlock Text="⚙️ Settings" FontSize="24" FontWeight="Bold" Foreground="#e6a817" Margin="0,0,0,20"/>
            <Border Background="#33000000" CornerRadius="12" Padding="25" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Currency" FontSize="16" FontWeight="SemiBold" Foreground="#CCFFFFFF" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtCurrentCurrency" Foreground="#AAFFFFFF" FontSize="13" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Switch to GH₵" Click="SwitchGhc_Click" Margin="0,0,10,0" Height="35" Foreground="White" Cursor="Hand">
                            <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="b" CornerRadius="6" Background="#44e6a817" BorderBrush="#88e6a817" BorderThickness="1" Padding="15,5"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#88e6a817"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                        </Button>
                        <Button Content="Switch to $" Click="SwitchUsd_Click" Height="35" Foreground="White" Cursor="Hand">
                            <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="b" CornerRadius="6" Background="#440f3460" BorderBrush="#880f3460" BorderThickness="1" Padding="15,5"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#880f3460"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Background="#33000000" CornerRadius="12" Padding="25" BorderBrush="#44FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Change Password" FontSize="16" FontWeight="SemiBold" Foreground="#CCFFFFFF" Margin="0,0,0,10"/>
                    <TextBlock Text="Current Password" Foreground="#AAFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="TxtCurrentPw" Height="35" FontSize="13" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Padding="8,5" CaretBrush="White" MaxWidth="300" HorizontalAlignment="Left"/>
                    <TextBlock Text="New Password" Foreground="#AAFFFFFF" FontSize="12" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="TxtNewPw" Height="35" FontSize="13" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Padding="8,5" CaretBrush="White" MaxWidth="300" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtPwStatus" Text="" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
                    <Button Content="Update Password" Click="ChangePw_Click" Margin="0,15,0,0" Height="38" Width="160" HorizontalAlignment="Left" FontSize="13" Foreground="White" Cursor="Hand">
                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="b" CornerRadius="6" Background="#88e6a817" Padding="10,5"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#AAe6a817"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
