<UserControl x:Class="LantelHotelApp.Views.FirstLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#33000000" CornerRadius="16" Padding="50"
                BorderBrush="#44FFFFFF" BorderThickness="1" MaxWidth="420">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🔐" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Change Your Password" FontSize="22" FontWeight="Bold"
                           Foreground="#e6a817" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="For security, you must set a new password before continuing."
                           Foreground="#AAFFFFFF" FontSize="12" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Current Password" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtCurrentPassword" Height="40" FontSize="14" Padding="10,8"
                             Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" CaretBrush="White">
                    <PasswordBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <TextBlock Text="New Password (min 8 chars)" Foreground="#CCFFFFFF" FontSize="12" Margin="0,15,0,5"/>
                <PasswordBox x:Name="TxtNewPassword" Height="40" FontSize="14" Padding="10,8"
                             Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" CaretBrush="White">
                    <PasswordBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <TextBlock Text="Confirm New Password" Foreground="#CCFFFFFF" FontSize="12" Margin="0,15,0,5"/>
                <PasswordBox x:Name="TxtConfirmPassword" Height="40" FontSize="14" Padding="10,8"
                             Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" CaretBrush="White">
                    <PasswordBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <TextBlock x:Name="TxtError" Text="" Foreground="#ff6b6b" FontSize="12"
                           TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>

                <Button x:Name="BtnChangePassword" Content="Set New Password" Click="ChangePassword_Click"
                        Margin="0,25,0,0" Height="44" FontSize="15" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#e6a817" Offset="0"/>
                                        <GradientStop Color="#ff6b35" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
