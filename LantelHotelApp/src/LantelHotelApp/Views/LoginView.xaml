<UserControl x:Class="LantelHotelApp.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#33000000" CornerRadius="16" Padding="50"
                BorderBrush="#44FFFFFF" BorderThickness="1"
                MaxWidth="420" MinWidth="380">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🏨" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Lantel Hotel" FontSize="28" FontWeight="Bold"
                           Foreground="#e6a817" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Management System" FontSize="14" Foreground="#88FFFFFF"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Username" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsername" Height="40" FontSize="14" Padding="10,8"
                         Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF"
                         CaretBrush="White">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Password" Foreground="#CCFFFFFF" FontSize="12" Margin="0,15,0,5"/>
                <PasswordBox x:Name="TxtPassword" Height="40" FontSize="14" Padding="10,8"
                             Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF"
                             CaretBrush="White" KeyDown="TxtPassword_KeyDown">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <TextBlock x:Name="TxtError" Text="" Foreground="#ff6b6b" FontSize="12"
                           TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>

                <Button x:Name="BtnLogin" Content="Sign In" Click="Login_Click"
                        Margin="0,25,0,0" Height="44" FontSize="15" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#e6a817" Offset="0"/>
                                        <GradientStop Color="#ff6b35" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Text="Default: admin / admin123" Foreground="#55FFFFFF" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Text="© 2025 Lantel Hotel Management Suite / DeonLondn"
                   Foreground="#44FFFFFF" FontSize="10"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
    </Grid>
</UserControl>
